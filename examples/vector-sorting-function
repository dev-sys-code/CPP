#include <iostream>
#include <vector>
#include <algorithm>

void numbers(const bool sorted, const std::vector<int> nums);

int main()
{
    using std::vector;
    using std::cout;
    using std::sort;

    bool valid{false};
    
    vector<int> nums{3, 2, 5, 4, 1};

    numbers(valid, nums);
    valid = !valid;
    sort(nums.begin(), nums.end());

    numbers(valid, nums);
    
    return 0;
}

void numbers(const bool sorted, const std::vector<int> nums) {

    if (sorted) {
        std::cout << "Sorted numbers: ";
    } else {
        std::cout << "Unsorted numbers: ";
    }


    for (int i : nums) {
        std::cout << i << " ";
    }

    std::cout << std::endl;
}
